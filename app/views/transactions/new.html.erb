<% content_for :title, "新增收支記錄" %>

<h1>新增收支記錄</h1>

<p class="actions">
  <%= link_to "查看收支記錄列表", transactions_path %>
</p>

<%= form_with model: @transaction, url: transactions_path do |form| %>
  <% if @transaction.errors.any? %>
    <div class="errors">
      <h2><%= pluralize(@transaction.errors.count, "個") %>錯誤，請修正後再送出：</h2>
      <ul>
        <% @transaction.errors.full_messages.each do |message| %>
          <li><%= message %></li>
        <% end %>
      </ul>
    </div>
  <% end %>

  <div class="field">
    <%= form.label :kind, "類型" %>
    <%= form.select :kind,
          [["支出", "expense"], ["收入", "income"]],
          { include_blank: "請選擇" } %>
  </div>

  <div class="field">
    <%= form.label :amount, "金額" %>
    <%= form.number_field :amount, min: 1, step: 1 %>
  </div>

  <div class="field">
    <%= form.label :occurred_on, "發生日期" %>
    <%= form.date_field :occurred_on %>
  </div>

  <div class="field">
    <%= form.label :category, "分類（可選）" %>
    <%= form.text_field :category %>
  </div>

  <div class="field">
    <%= form.label :note, "備註（可選）" %>
    <%= form.text_area :note, rows: 3 %>
  </div>

  <div class="actions">
    <%= form.submit "新增" %>
  </div>
<% end %>
